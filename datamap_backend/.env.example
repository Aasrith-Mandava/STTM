# Standalone (no GCP/Vertex). Get a free key at https://aistudio.google.com/apikey
GOOGLE_API_KEY=
GOOGLE_GENAI_USE_VERTEXAI=FALSE

# --- Auth ---
# Standalone default: "dev" runs with no Launchpad and no login (a default
# local user is assumed). Other modes: "launchpad_sso" (trust a Launchpad JWT,
# requires SECRET_KEY) or "iap" (Google IAP headers).
APP_SESSION_AUTH_MODE=dev
# Optional CORS override (comma-separated). Defaults to local origins.
# DATAMAP_CORS_ORIGINS=https://your-frontend-host,https://your-api-host
