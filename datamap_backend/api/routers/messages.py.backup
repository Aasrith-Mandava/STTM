                            #         num_dart_tables = len(raw_response.get("dart_tables", []))

                            #         logging.info(f"[send-stream] Metadata fetched: {num_source_tables} source tables, {num_dart_tables} DART tables")

                            #         tracker_init = ensure_tracker(FeatureType.SIMILARITY, total_items=num_source_tables + num_dart_tables, message="Similarity analysis in progress...")
                            #         if tracker_init:
                            #             yield tracker_init

                            #         # Emit Phase 1 progress (30% complete - metadata fetching done)
                            #         yield {
                            #             "event": "progress",
                            #             "data": json.dumps({
                            #                 "phase": "metadata_fetching",
                            #                 "feature": "similarity",
                            #                 "message": f"Metadata fetched for {num_source_tables} source tables. Starting semantic matching...",
                            #                 "progress": 30,
                            #                 "phase_progress": 100,
                            #                 "source_tables": num_source_tables,
                            #                 "dart_tables": num_dart_tables
                            #             })
                            #         }

                            #         # Don't break - let agent continue to semantic matching (Phase 1b) and overlap validation (Phase 2)
                            #         # The final_similarity_response will be handled by the output_key handler at line 777-780

                            #     except Exception as e:
                            #         logging.error(f"[send-stream] Error processing metadata fetch: {e}")
                            #         import traceback
                            #         traceback.print_exc()

                            # Handle similarity compute_overlap_tool completion (Phase 2)
                            # elif func_response.name == "compute_overlap_tool":
                            #     # Note: This tool is called multiple times (once per potential match)
                            #     # We track cumulative progress across all calls
                            #     logging.info("[send-stream] ✓ Similarity overlap validation (single match)")

                            #     try:
                            #         # This is a single match result
                            #         # We can't easily track total progress here since agent calls this sequentially
                            #         # Just log for now - full results will come via final_similarity_response

                            #         overlap_result = func_response.response
                            #         if isinstance(overlap_result, str):
                            #             overlap_result = json.loads(overlap_result)

                            #         logging.info(f"[send-stream] Overlap calculated: {overlap_result.get('data_overlap_percent', 0):.1f}% match")

                            #         # Don't emit progress per match (too granular) - wait for final_similarity_response
                            #         # The agent will continue calling this tool for remaining matches

                            #     except Exception as e:
                            #         logging.error(f"[send-stream] Error processing overlap validation: {e}")
                            #         import traceback
                            #         traceback.print_exc()

                # Check if we should exit outer loop
                if should_exit:
                    break

                # Handle intermediate content responses (for text-based responses)
                if hasattr(event, "content") and event.content and \
                   hasattr(event.content, "parts") and event.content.parts and \
                   len(event.content.parts) > 0 and getattr(event.content.parts[0], "text", None):

                    obj = event.content.parts[0].text

                    # Check if it's a final response (JSON format)
                    if isinstance(obj, dict):
                        feature_hint = tracker.feature_type if tracker else FeatureType.PROFILING
                        for event_payload in emit_complete_events(obj, feature_hint):
                            yield event_payload
                        break
                    elif isinstance(obj, str):
                        new_obj = extract_json_from_string(obj)
                        if new_obj:
                            try:
                                parsed_obj = json.loads(new_obj)
                                feature_hint = tracker.feature_type if tracker else FeatureType.PROFILING
                                for event_payload in emit_complete_events(parsed_obj, feature_hint):
                                    yield event_payload
                                break
                            except json.JSONDecodeError:
                                pass

                # Handle errors
                if hasattr(event, 'error_code') and event.error_code:
                    if event.error_code == 'MALFORMED_FUNCTION_CALL':
                        # Try to extract response from malformed call
                        stage = get_text_between_brackets(req["newMessage"]['parts'][0]['text'])
                        output = format_output(stage, event)

                        feature_hint = tracker.feature_type if tracker else FeatureType.PROFILING
                        for event_payload in emit_complete_events(output, feature_hint):
                            yield event_payload
                        break
                    else:
                        error_message = f"{event.error_code}: {getattr(event, 'error_message', 'Unknown error')}"
                        feature_hint = tracker.feature_type if tracker else FeatureType.PROFILING
                        for error_payload in emit_error_events(error_message, feature_hint):
                            yield error_payload
                        break

                # Heartbeat - keep connection alive
                await asyncio.sleep(0.1)  # Small delay to prevent overwhelming client

            # If we exited loop without completion event, send generic complete
            feature_label = tracker.feature_type.value if tracker else "unknown"
            logging.info(f"SSE Stream completed for feature: {feature_label}")

        except Exception as e:
            logging.error(f"Error in SSE stream: {e}")
            import traceback
            traceback.print_exc()

            feature_hint = tracker.feature_type if tracker else FeatureType.PROFILING
            for error_payload in emit_error_events(f"Stream error: {str(e)}", feature_hint):
                yield error_payload

    return EventSourceResponse(event_generator())


@router.post("/similarity-check")
async def similarity_check(request: MessageRequest):
    """
    Dedicated endpoint for Smart Similarity Agent (SequentialAgent with 2 phases)
    Phase 1: Semantic matching - identifies potential column matches
    Phase 2: Overlap validation - calculates data overlap and generates final report
    """
    try:
        req = request.dict()
        print("Similarity Check Request received:", req)

        session_service = VertexAiSessionService(
            project=config.PROJECT_ID,
            location=config.LOCATION)

        session_id = req.get("sessionId")

        orchestrator_app = App(
            name=req["appName"],
            root_agent=root_agent,
        )

        runner = Runner(app=orchestrator_app, session_service=session_service)
        print("Runner initialized for similarity check")

        msg = types.Content(role="user", parts=[types.Part(text=req["newMessage"]['parts'][0]['text'])])

        response_parts = []
        event_count = 0

        print("="*100)
        print(f"User ID: {req['userId']}")
        print(f"Session ID: {session_id}")
        print(f"Message: {msg}")
        print("="*100)

        async for event in runner.run_async(
            user_id=req["userId"],
            session_id=session_id,
            new_message=msg
        ):
            event_count += 1
            print(f"Received event #{event_count}")

            # PRIMARY CHECK: Look for final_similarity_response in state_delta (Phase 2 output)
            if (hasattr(event, "actions") and event.actions and hasattr(event.actions, "state_delta")):
                if 'final_similarity_response' in event.actions.state_delta:
                    logging.info("="*100)
                    logging.info(f"✅ FINAL SIMILARITY RESPONSE CAPTURED (Phase 2 Complete)")
                    logging.info(f"Event: {event}")
                    logging.info("="*100)

                    response_parts.append(event.actions.state_delta['final_similarity_response'])
                    break

            # INTERMEDIATE CHECK: Detect Phase 1 output and continue to Phase 2
            if (hasattr(event, "content") and event.content and
                hasattr(event.content, "parts") and event.content.parts and
                len(event.content.parts) > 0 and
                getattr(event.content.parts[0], "text", None)):

                obj = event.content.parts[0].text

                if isinstance(obj, str):
                    try:
                        parsed_obj = json.loads(obj)

                        # Check if this is Phase 1 intermediate output
                        if isinstance(parsed_obj, dict) and "tool_response" in parsed_obj:
                            tool_resp = parsed_obj.get("tool_response", {})
                            if isinstance(tool_resp, dict) and tool_resp.get("store_for_next_agent") == True:
                                logging.info("="*100)
                                logging.info(f"🔄 Phase 1 Complete - Semantic Matching Done")
                                logging.info(f"Potential matches found: {len(tool_resp.get('potential_matches', []))}")
                                logging.info("Continuing to Phase 2 (Overlap Validation)...")
                                logging.info("="*100)
                                # DON'T break - continue to Phase 2
                                continue

                        # If we get here, it's an unexpected format - log but continue
                        logging.warning(f"Unexpected JSON format in event #{event_count}: {str(parsed_obj)[:200]}")

                    except json.JSONDecodeError as e:
                        logging.warning(f"JSON decode error in event #{event_count}: {e}")
                        continue

            # ERROR HANDLING: Malformed function call
            if(hasattr(event, 'error_code') and event.error_code and event.error_code == 'MALFORMED_FUNCTION_CALL'):
                print("*"*100)
                print(f"MALFORMED_FUNCTION_CALL error in event #{event_count}")
                print(event)
                print("*"*100)

                result = extract_response_from_malformed_call(f"{event}")
                if result:
                    response_parts.append(result)
                    break

        # Final response handling
        if not response_parts:
            return [{'text_response': 'Smart Similarity analysis did not complete. No results found.', 'tool_response':{}, 'should_update':False}]

        return response_parts

    except Exception as e:
        logging.error(f"Error in similarity check: {e}")
        import traceback
        traceback.print_exc()
        return [{'text_response': f'Similarity check failed: {str(e)}', 'tool_response':{}, 'should_update':False}]



@router.post("/qa")
async def send_message(request: QARequest):
    try:
        req = request.dict()
        # print("Request received:", req)

        session_service = VertexAiSessionService(
            project=config.PROJECT_ID,
            location=config.LOCATION        )


        # Ensure session exists
        session_id = req.get("sessionId")

        
        qa_app = App(
            name=req["appName"],
            root_agent=qa_root_agent,
        )

        runner = Runner(app=qa_app, session_service=session_service)

        msg = types.Content(role="user", parts=[types.Part(text=req["newMessage"])])

        response_parts = []

        async for event in runner.run_async(

            user_id=req["userId"],
            session_id=session_id,
            new_message=msg
        ):
            logging.info("="*100)
            logging.info(f"Event: {event}")
            logging.info("="*100)

            # await session_service.append_event(session=session, event=event)

            response_parts.append(event)




        return response_parts

    except Exception as e:
        raise HTTPException(status_code=500, detail=f"Error sending message: {e}")
    


